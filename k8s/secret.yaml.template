apiVersion: v1
kind: Secret
metadata:
  name: user-service-secret
  namespace: user-service
type: Opaque
data:
  # Base64로 인코딩된 값을 입력하세요
  # echo -n "your-value" | base64
  
  SECRET_KEY: <BASE64_ENCODED_JWT_SECRET>
  RDS_PASSWORD: <BASE64_ENCODED_RDS_PASSWORD>
  GEMINI_API_KEY: <BASE64_ENCODED_GEMINI_API_KEY>
  
  # AWS 자격증명은 Pod Identity로 자동 관리됨
